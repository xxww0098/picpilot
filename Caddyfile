{
	auto_https off
	log {
		format filter {
			wrap json
			fields {
				request>headers>Authorization delete
				request>headers>Proxy-Authorization delete
				request>headers>X-Picpilot-Authorization delete
				request>headers>X-PicPilot-Authorization delete
				request>headers>Cookie delete
			}
		}
	}
}

:80 {
	bind 0.0.0.0

	root * /usr/share/caddy
	encode zstd gzip

	request_body {
		max_size 600MB
	}

	header {
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Content-Type-Options "nosniff"
	}

	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	@api path /api/auth/* /api/admin/* /api/telemetry/* /api/gallery* /api/notifications* /api/avatars/*
	handle @api {
		reverse_proxy auth:3001 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
		}
	}

	@api_proxy_allowed {
		path /api-proxy/*
		method POST OPTIONS
	}
	handle @api_proxy_allowed {
		reverse_proxy auth:3001 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			transport http {
				dial_timeout 60s
				response_header_timeout 600s
				read_timeout 600s
				write_timeout 600s
			}
		}
	}

	handle /api-proxy/ {
		respond "Forbidden: API Proxy path required" 403
	}

	handle /api-proxy/* {
		respond "Method Not Allowed" 405
	}

	handle {
		try_files {path} {path}/ /index.html
		file_server
	}
}
