{
  "name": "picpilot",
  "private": true,
  "version": "0.1.28",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "vite",
    "start:local": "tsx scripts/run-local.ts",
    "mock:api": "tsx scripts/mock-image-api.ts",
    "build:sw": "tsc -p tsconfig.sw.json && tsx scripts/inject-sw-version.ts",
    "typecheck": "tsc -b && tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.sw.json --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "build": "npm run typecheck && vite build && npm run build:sw",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@xyflow/react": "^12.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fflate": "^0.8.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^6.3.2",
    "vitest": "^4.1.5"
  }
}
