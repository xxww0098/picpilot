# 生产 VPS 主机栈（/opt/picpilot/compose.yml）所需环境变量示例。
# 实盘真值放在 /opt/picpilot/.env（在仓库之外，勿提交）。本文件仅占位 + 说明。

# 管理员账号，形如 user:password（首个会被种子为管理员）
ADMIN_USERS=admin:change-me

# 后端 JWT 签名密钥（至少 32 字符）
JWT_SECRET=please-generate-a-long-random-secret-at-least-32-chars

# 上游模式：api = API/CLIProxyAPI；reverse = Go 内置 ChatGPT 逆向接口。
UPSTREAM_MODE=api

# API 模式上游出图代理（cliproxy）地址与密钥
API_PROXY_URL=http://cliproxy:8317/v1
API_PROXY_API_KEY=
CLIPROXY_API_URL=http://cliproxy:8317
CLIPROXY_MGMT_KEY=

# reverse 模式默认使用 Go 内置实现，不依赖 chatgpt2api 容器。
REVERSE_PROXY_URL=internal
# 逆向账号统一存入 PicPilot SQLite 数据库；管理员在「管理面板 -> 逆向账号」导入 JSON。
CHATGPT_REVERSE_BASE_URL=https://chatgpt.com
# 如仍需外部 chatgpt2api，可把 REVERSE_PROXY_URL 改为 http://chatgpt2api/v1 并填写下面的 key。
REVERSE_PROXY_API_KEY=
CHATGPT2API_AUTH_KEY=

# 服务端全局出站代理默认值（可在管理端「团队设置」运行时调整）。
# 类型支持 env / none / http / https / socks5 / socks5h；env 表示继续读取容器 HTTP_PROXY / HTTPS_PROXY。
OUTBOUND_PROXY_TYPE=env
OUTBOUND_PROXY_URL=

# 全局并发/排队上限（详见 AGENTS.md）。6 个 Plus 账号允许 5 个 PicPilot 并发，保留 1 个上游余量。
MAX_CONCURRENT_PROXY_REQUESTS=5
PROXY_QUEUE_MAX=10
PROXY_QUEUE_MAX_WAIT_MS=240000
# 单用户在途软上限（0=关闭）。队首用户已占满时，会优先放行后方其他用户。
PROXY_USER_SOFT_LIMIT=3
# 统一请求超时（秒）与图像流式失败回退开关，可在管理端运行时覆盖。
REQUEST_TIMEOUT_SECONDS=900
STREAM_FALLBACK_ENABLED=true

# dockercopilot 管理面板密钥（实盘曾硬编码在 compose 里，已改为此变量）
DOCKERCOPILOT_SECRET=please-generate-a-random-secret

# 部署版本号（镜像标签，不带 v 前缀，如 0.1.7）；deploy.sh 会按版本覆盖此值
PICPILOT_VERSION=latest
