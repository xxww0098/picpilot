# 生产 VPS 主机栈（/opt/picpilot/compose.yml）所需环境变量示例。
# 实盘真值放在 /opt/picpilot/.env（在仓库之外，勿提交）。本文件仅占位 + 说明。

# 管理员账号，形如 user:password（首个会被种子为管理员）
ADMIN_USERS=admin:change-me

# 后端 JWT 签名密钥（至少 32 字符）
JWT_SECRET=please-generate-a-long-random-secret-at-least-32-chars

# 上游出图代理（cliproxy）地址与密钥
API_PROXY_URL=http://cliproxy:8317/v1
API_PROXY_API_KEY=
CLIPROXY_API_URL=http://cliproxy:8317
CLIPROXY_MGMT_KEY=

# 全局并发/排队上限（详见 AGENTS.md）。6 个 Plus 账号允许 5 个 PicPilot 并发，保留 1 个上游余量。
MAX_CONCURRENT_PROXY_REQUESTS=5
PROXY_QUEUE_MAX=10
PROXY_QUEUE_MAX_WAIT_MS=240000

# dockercopilot 管理面板密钥（实盘曾硬编码在 compose 里，已改为此变量）
DOCKERCOPILOT_SECRET=please-generate-a-random-secret

# 部署版本号（镜像标签，不带 v 前缀，如 0.1.7）；deploy.sh 会按版本覆盖此值
PICPILOT_VERSION=latest
