# auth（Go server）同时托管前端静态文件与 /api、/api-proxy，长超时覆盖出图流式响应。
image.xxww.online {
	encode zstd gzip

	request_body {
		max_size 600MB
	}

	header {
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Content-Type-Options "nosniff"
	}

	reverse_proxy auth:3001 {
		header_up X-Real-IP {remote_host}
		transport http {
			dial_timeout 60s
			response_header_timeout 600s
			read_timeout 600s
			write_timeout 600s
		}
	}
}

api.xxww.online {
	reverse_proxy cliproxy:8317 {
		transport http {
			dial_timeout 60s
			response_header_timeout 600s
			read_timeout 600s
			write_timeout 600s
		}
	}
}

dc.xxww.online {
	reverse_proxy dockercopilot:12712
}
