# CLIProxyAPI (cliproxyapi) 独立部署 .env 示例
# 复制为 .env （或 export），放在 /opt/cliproxyapi/ 下

# 镜像与拉取
CLI_PROXY_IMAGE=eceasy/cli-proxy-api:latest
PULL_POLICY=always
DEPLOY=docker

# === 端口映射（关键隔离）===
HOST_8317=8317
HOST_8085=8085
HOST_1455=1455
HOST_54545=54545
HOST_51121=51121
HOST_11451=11451

# === 数据卷路径（用 cliproxyapi 专属子目录）===
CONFIG_PATH=./data/config/config.yaml
AUTHS_PATH=./data/auths
LOGS_PATH=./data/logs
PLUGINS_PATH=./data/plugins

# 生产目录建议：
# mkdir -p /opt/cliproxyapi/data/{config,auths,logs,plugins}
# cp config.example.yaml /opt/cliproxyapi/data/config/config.yaml   # 从本目录官方依赖文件复制并编辑（必须！）
# cd /opt/cliproxyapi && docker compose -p cliproxyapi -f compose.yml up -d

# PicPilot 等上层应用通过 env 变量指向这里：
# API_PROXY_URL=http://cli-proxy-api:8317/v1
# CLIPROXY_API_URL=http://cli-proxy-api:8317
# （同主机时可加入 cliproxyapi-net 网络使用服务名解析）

# 依赖文件：config.example.yaml 来自 https://github.com/router-for-me/CLIProxyAPI/blob/main/config.example.yaml
# 复制后根据你的 providers（gemini-api-key、codex、claude、openai-compatibility 等）填写。
