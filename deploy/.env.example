# picpilot 部署环境变量
# 复制此文件为 .env 并填入实际值：
#   cp deploy/.env.example deploy/.env
# 然后启动：
#   docker compose -f deploy/docker-compose.yml up -d --build

# ===== 必填 =====

# JWT 签名密钥（生产环境请使用长随机串）
# 生成命令：openssl rand -hex 32
JWT_SECRET=

# 管理员账号，格式：用户名:密码
# 首次启动时创建，后续通过邀请码注册其他用户
ADMIN_USERS=admin:your-strong-password

# 上游 API 地址（OpenAI 兼容接口需写到 /v1）
# 如果 CLIProxyAPI 在同一 compose 中，使用服务名：
API_PROXY_URL=http://cli-proxy-api:8317/v1

# 上游 API Key
API_PROXY_API_KEY=

# ===== 可选 =====

# 公网域名（用于 Caddy 反向代理）
PUBLIC_ORIGIN=picpilot.example.com

# 自定义服务商 JSON 配置 URL（页面启动后自动导入）
DEFAULT_API_URL=

# 新用户默认每小时生图配额（0 = 暂停团队服务）
DEFAULT_HOURLY_IMAGE_QUOTA=100

# 单次批量任务最多生成图片数
DEFAULT_MAX_BATCH_IMAGES=10

# 每用户公开画廊存储配额（字节，默认 500MB）
PER_USER_PUBLIC_QUOTA_BYTES=524288000

# 事件流水保留天数
EVENT_RETENTION_DAYS=30

# JWT 有效期（秒，默认 30 天）
JWT_EXPIRES_IN_SECONDS=2592000