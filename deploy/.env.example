# picpilot 部署环境变量
# 复制此文件为 .env 并填入实际值：
#   cp deploy/.env.example deploy/.env

# ===== 必填 =====

# JWT 签名密钥（至少 32 字符，openssl rand -hex 32 生成）
JWT_SECRET=

# 管理员账号，格式：用户名:密码
ADMIN_USERS=admin:your-strong-password

# API 模式上游 Key（CLIProxyAPI 的 API Key；UPSTREAM_MODE=api 时需要）
API_PROXY_API_KEY=

# ===== 可选 =====

# 上游模式：api = API/CLIProxyAPI；reverse = Go 内置 ChatGPT 逆向接口。
# UPSTREAM_MODE=api

# 上游 API 地址（默认 http://cli-proxy-api:8317/v1，同 compose 网络内使用服务名）
# API_PROXY_URL=http://cli-proxy-api:8317/v1

# Go 内置 reverse（UPSTREAM_MODE=reverse 时推荐）：逆向账号统一存入 PicPilot SQLite 数据库。
# 管理员可在「管理面板 -> 逆向账号」导入 ChatGPT OAuth JSON。
# REVERSE_PROXY_URL=internal
# CHATGPT_REVERSE_BASE_URL=https://chatgpt.com
#
# 如仍需外部 chatgpt2api，可把 REVERSE_PROXY_URL 改为 http://chatgpt2api/v1，
# 并填写 REVERSE_PROXY_API_KEY 或 CHATGPT2API_AUTH_KEY。
# REVERSE_PROXY_API_KEY=
# CHATGPT2API_AUTH_KEY=

# CLIProxyAPI 管理密钥（用于查询凭证状态，可选）
# CLIPROXY_MGMT_KEY=

# 服务端全局出站代理默认值（可在管理端「团队设置」运行时调整）。
# 类型支持 env / none / http / https / socks5 / socks5h；env 表示继续读取容器 HTTP_PROXY / HTTPS_PROXY。
# OUTBOUND_PROXY_TYPE=env
# OUTBOUND_PROXY_URL=

# 团队最大并发代理请求数（默认 5）。超出的请求进 FIFO 队列排队，不是直接拒绝。
# 可在管理端「团队设置」运行时调整，无需重启。
# MAX_CONCURRENT_PROXY_REQUESTS=5
# 账号越多可适当调高：经验上「上游 Plus 账号数 - 1」≈ 每账号约 1 个并发、留 1 个余量。
# 例如 11 个 Plus 账号建议 MAX_CONCURRENT_PROXY_REQUESTS=10、PROXY_QUEUE_MAX=20。

# 排队队列长度上限（默认 10）：队满时新请求立即 429，避免无限堆积。建议设为并发上限的 ~2 倍。
# PROXY_QUEUE_MAX=10

# 排队等待上限（毫秒，默认 240000，最大钳到 240000）：等待超时返回 429。
# PROXY_QUEUE_MAX_WAIT_MS=240000

# 单用户在途软上限（默认 3，0 表示关闭）：队首用户已占满时，会优先放行后方其他用户。
# PROXY_USER_SOFT_LIMIT=3

# 上游瞬时失败自动重试次数（默认 2，范围 0-5，server-go 异步任务路径生效）：
# 对 5xx / 429 / 网络错误做指数退避重试，服务端完成、客户端无感，显著降低有效失败率。
# UPSTREAM_MAX_RETRIES=2

# 统一请求超时（秒，默认 900，上限 3600）：可在管理端运行时调整。
# REQUEST_TIMEOUT_SECONDS=900

# 图像流式失败自动关闭流式并重试（默认 true）：可在管理端运行时调整。
# STREAM_FALLBACK_ENABLED=true

# 单次批量任务最多生成图片数（默认 10，上限 10）
# DEFAULT_MAX_BATCH_IMAGES=10

# 每用户公开画廊存储配额（字节，默认 500MB）
# PER_USER_PUBLIC_QUOTA_BYTES=524288000

# 事件流水保留天数
# EVENT_RETENTION_DAYS=30

# 访问令牌有效期（秒，默认 2h=7200）。前端在过期前静默刷新（/api/auth/refresh），
# 泄露但未刷新的令牌最多 2h 后失效。嫌登出太频繁就调大这个值（不是 30 天，别被旧文档误导）。
# JWT_EXPIRES_IN_SECONDS=7200

# 会话绝对上限（秒，默认 7d=604800）：从登录那一刻起算，超过即使一直刷新也必须重新登录。
# JWT_SESSION_MAX_SECONDS=604800

# 日志级别（默认 info：trace/debug/info/warn/error/fatal）
# LOG_LEVEL=info

# 本地开发美化日志（设为 1 启用 pino-pretty，生产留空走 JSON 行）
# LOG_PRETTY=1
