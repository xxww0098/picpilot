# picpilot 部署环境变量
# 复制此文件为 .env 并填入实际值：
#   cp deploy/.env.example deploy/.env

# ===== 必填 =====

# JWT 签名密钥（至少 32 字符，openssl rand -hex 32 生成）
JWT_SECRET=

# 管理员账号，格式：用户名:密码
ADMIN_USERS=admin:your-strong-password

# 上游 API Key（CLIProxyAPI 的 API Key）
API_PROXY_API_KEY=

# ===== 可选 =====

# 上游 API 地址（默认 http://cli-proxy-api:8317/v1，同 compose 网络内使用服务名）
# API_PROXY_URL=http://cli-proxy-api:8317/v1

# CLIProxyAPI 管理密钥（用于查询凭证状态，可选）
# CLIPROXY_MGMT_KEY=

# 团队最大并发代理请求数（默认 5）。超出的请求进 FIFO 队列排队，不是直接拒绝。
# 可在管理端「团队设置」运行时调整，无需重启。
# MAX_CONCURRENT_PROXY_REQUESTS=5

# 排队队列长度上限（默认 10）：队满时新请求立即 429，避免无限堆积。
# PROXY_QUEUE_MAX=10

# 排队等待上限（毫秒，默认 240000，最大钳到 240000）：等待超时返回 429。
# PROXY_QUEUE_MAX_WAIT_MS=240000

# 单次批量任务最多生成图片数（默认 10，上限 10）
# DEFAULT_MAX_BATCH_IMAGES=10

# 每用户公开画廊存储配额（字节，默认 500MB）
# PER_USER_PUBLIC_QUOTA_BYTES=524288000

# 事件流水保留天数
# EVENT_RETENTION_DAYS=30

# 访问令牌有效期（秒，默认 2h=7200）。前端在过期前静默刷新（/api/auth/refresh），
# 泄露但未刷新的令牌最多 2h 后失效。嫌登出太频繁就调大这个值（不是 30 天，别被旧文档误导）。
# JWT_EXPIRES_IN_SECONDS=7200

# 会话绝对上限（秒，默认 7d=604800）：从登录那一刻起算，超过即使一直刷新也必须重新登录。
# JWT_SESSION_MAX_SECONDS=604800

# 日志级别（默认 info：trace/debug/info/warn/error/fatal）
# LOG_LEVEL=info

# 本地开发美化日志（设为 1 启用 pino-pretty，生产留空走 JSON 行）
# LOG_PRETTY=1
