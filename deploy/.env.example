# picpilot 部署环境变量
# 把这个文件复制成 .env 后再填入实际值：
#   cp deploy/.env.example deploy/.env
# 然后 cd deploy && docker compose up -d

# ===== 必填 =====

# JWT 签名密钥。生产环境请使用长随机串，例如 `openssl rand -hex 32`
JWT_SECRET=

# 引导期管理员账号列表。格式：`用户名:初始密码`，多个用逗号分隔。
# 首次启动时会创建这些账号；后续请通过邀请码注册其他用户，并尽快在管理面板修改密码。
# 示例：admin:please-change-me,alice:s3cret
ADMIN_USERS=

# ===== 上游 API（关键）=====
# picpilot 把所有 OpenAI 兼容请求转发到这里。前端用户不再能在 UI 里
# 设置 base url / API Key，所有上游凭据都来自这两个变量。

# 上游 API 基础地址。OpenAI 兼容接口需要写到版本前缀，例如：
#   API_PROXY_URL=https://api.openai.com/v1
# 或自托管的 OpenAI 兼容代理：
#   API_PROXY_URL=http://cliproxyapi:8317/v1
API_PROXY_URL=

# 上游 API Key（picpilot 会用这个值给所有请求添加 Authorization: Bearer ...）
API_PROXY_API_KEY=

# ===== 可选：配额 / 限制 =====

# 新注册用户默认的每小时生图上限。0 = 暂停团队服务（仅管理员可生图）
DEFAULT_HOURLY_IMAGE_QUOTA=100

# 单次批量任务最多生成的图片张数
DEFAULT_MAX_BATCH_IMAGES=10

# 每个用户公开画廊的存储配额（字节）。默认 500 MB
PER_USER_PUBLIC_QUOTA_BYTES=524288000

# 事件流水保留天数（用于管理面板「事件流水」Tab）
EVENT_RETENTION_DAYS=30

# JWT token 有效期（秒）。默认 30 天
JWT_EXPIRES_IN_SECONDS=2592000

# ===== 可选：前端默认值 =====

# 可填一个 .json 配置 URL 或带 settings 参数的分享 URL，在页面启动后自动导入自定义服务商配置。
# 普通 API 地址会被前端忽略，实际请求由后端代理决定。
DEFAULT_API_URL=

# ===== 可选：监听端口 =====

# Caddy 监听端口（容器外端口由 docker-compose.yml 的 ports 决定）
PORT=80
