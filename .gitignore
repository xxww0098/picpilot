# Dependencies
node_modules/
server/node_modules/

# Build output
dist/
.wrangler/

# Local dev config
dev-proxy.config.json

# Environment / secrets
.env
.env.*
!.env.example

# Runtime data (auth.db, avatars, uploaded images, etc.)
data/

# Deployment secrets & credentials (real OAuth tokens, management keys)
# Keep only examples/templates tracked; never commit real prod credentials.
deploy/cliproxyapi/auths/*.json
deploy/cliproxyapi/config.yaml
deploy/cliproxyapi/logs/*
!deploy/cliproxyapi/logs/.gitkeep

# Local overrides
*.local

# Editor / IDE / agent settings
.agents/
.claude/*
!.claude/skills/
.claude/skills/impeccable/
skills-lock.json
.vscode/
.idea/
.DS_Store

# Temporary outputs
tmp/
